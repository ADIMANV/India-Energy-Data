# Copy to .env (gitignored).
# Local dev: scripts/tick.sh sources this for cron runs.
# VPS: deploy/docker-compose.prod.yml reads it via --env-file.

# --- required on the VPS ---
# Postgres superuser password for the dockerized DB
POSTGRES_PASSWORD=change-me

# Domain for the API (DNS A record -> VPS IP). Caddy gets Let's Encrypt certs
# for it automatically. The Vercel frontend needs https, not http://ip:port.
API_DOMAIN=api.example.com

# --- optional ---
# healthchecks.io ping URL — tick.py pings it ONLY after a fully successful
# tick (all sources fetched+parsed, bounds clean, cross-check + staleness OK).
# A failed tick stays silent and healthchecks.io alerts on the missed ping.
#HEALTHCHECK_URL=https://hc-ping.com/<your-uuid>

# Postgres DSN override for local dev (default matches root docker-compose)
#GRID_DB_DSN=postgresql://grid:grid@localhost:5433/india_grid
